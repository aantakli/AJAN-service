<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://maven.apache.org/POM/4.0.0"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <artifactId>MappingPlugin</artifactId>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <configuration>
              <excludeArtifactIds>
                rdfbeans,
                gdx-ai,
                behaviour,
                loader,
                common,
                lombok,
                jackson-databind,
                xercesImpl,
                opencsv,
                rdf4j-model,
                rdf4j-model-compiance,
                rdf4j-repository-api
              </excludeArtifactIds>
              <excludeTransitive>true</excludeTransitive>
              <outputDirectory>${project.build.directory}/lib</outputDirectory>
              <overWriteReleases>false</overWriteReleases>
              <overWriteSnapshots>true</overWriteSnapshots>
            </configuration>
            <goals>
              <goal>copy-dependencies</goal>
            </goals>
            <phase>install</phase>
          </execution>
        </executions>
        <version>3.0.0</version>
      </plugin>
    </plugins>
  </build>
  <dependencies>

    <dependency>
      <artifactId>carml-engine</artifactId>
      <exclusions>
        <exclusion>
          <artifactId>slf4j-api</artifactId>
          <groupId>org.slf4j</groupId>
        </exclusion>
      </exclusions>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-commons</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-model</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-rdf-mapper</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-logical-source-resolver-jsonpath</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-logical-source-resolver-xpath</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-logical-source-resolver-csv</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>commons-lang3</artifactId>
      <groupId>org.apache.commons</groupId>
      <version>3.8</version>
    </dependency>
    <dependency>
      <artifactId>javax.inject</artifactId>
      <groupId>javax.inject</groupId>
      <version>1</version>
    </dependency>
    <dependency>
      <artifactId>Saxon-HE</artifactId>
      <groupId>net.sf.saxon</groupId>
      <version>9.8.0-12</version>
    </dependency>
    <dependency>
      <artifactId>xercesImpl</artifactId>
      <groupId>xerces</groupId>
      <version>2.12.1</version>
    </dependency>
    <dependency>
      <artifactId>opencsv</artifactId>
      <groupId>com.opencsv</groupId>
      <type>jar</type>
      <version>4.6</version>
    </dependency>
    <dependency>
      <artifactId>univocity-parsers</artifactId>
      <groupId>com.univocity</groupId>
      <version>2.9.1</version>
    </dependency>
    <dependency>
      <artifactId>logback-classic</artifactId>
      <exclusions>
        <exclusion>
          <artifactId>slf4j-simple</artifactId>
          <groupId>org.slf4j</groupId>
        </exclusion>
        <exclusion>
          <artifactId>slf4j-api</artifactId>
          <groupId>org.slf4j</groupId>
        </exclusion>
      </exclusions>
      <groupId>ch.qos.logback</groupId>
      <version>1.2.3</version>
    </dependency>
    <dependency>
      <artifactId>commons-lang</artifactId>
      <groupId>commons-lang</groupId>
      <version>2.6</version>
    </dependency>
    <dependency>
      <artifactId>commons-cli</artifactId>
      <groupId>commons-cli</groupId>
