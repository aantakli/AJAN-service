      <version>20201115</version>
    </dependency>
  </dependencies>

  <modelVersion>4.0.0</modelVersion>

  <packaging>jar</packaging>

  <parent>
    <artifactId>plugins</artifactId>
    <groupId>de.dfki.asr.ajan.pluginsystem</groupId>
    <version>0.1</version>
  </parent>

  <properties>
    <carml.version>0.3.2</carml.version>
    <netbeans.hint.license>licenseheader</netbeans.hint.license>
    <plugin.class>de.dfki.asr.ajan.pluginsystem.mappingplugin.MappingPlugin</plugin.class>
    <plugin.dependencies/>
    <plugin.id>MappingPlugin</plugin.id>
    <plugin.provider>Andre Antakli</plugin.provider>
    <plugin.version>0.0.1</plugin.version>
  </properties>

  <repositories>
    <repository>
      <id>lib</id>
      <url>file:///${project.basedir}/lib</url>
    </repository>
  </repositories>
</project>