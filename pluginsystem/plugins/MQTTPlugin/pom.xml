  </dependencies>
  <modelVersion>4.0.0</modelVersion>
  <name>MQTTPlugin</name>

  <packaging>jar</packaging>
  <parent>
    <artifactId>plugins</artifactId>
    <groupId>de.dfki.asr.ajan.pluginsystem</groupId>
    <version>0.1</version>
  </parent>
  <properties>
    <carml.version>0.3.2</carml.version>
  </properties>

</project>