<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://maven.apache.org/POM/4.0.0"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <artifactId>MQTTPlugin</artifactId>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <configuration>
              <excludeArtifactIds>
                rdfbeans,
                gdx-ai,
                behaviour,
                executionservice,
                loader,
                common,
                lombok,
                jackson-databind,
                pf4j,
                rdf4j-model,
                rdf4j-repository-api
              </excludeArtifactIds>
              <excludeTransitive>true</excludeTransitive>
              <outputDirectory>${project.build.directory}/lib</outputDirectory>
              <overWriteReleases>false</overWriteReleases>
              <overWriteSnapshots>true</overWriteSnapshots>
            </configuration>
            <goals>
              <goal>copy-dependencies</goal>
            </goals>
            <phase>install</phase>
          </execution>
        </executions>
        <version>3.0.0</version>
      </plugin>
    </plugins>
  </build>

  <dependencies>
    <dependency>
      <artifactId>org.eclipse.paho.client.mqttv3</artifactId>
      <groupId>org.eclipse.paho</groupId>
      <version>1.2.5</version>
    </dependency>
    <dependency>
      <artifactId>moquette-broker</artifactId>
      <groupId>io.moquette</groupId>
      <version>0.15</version>
      <!--            <scope>test</scope>-->
    </dependency>
    <!-- dependencies for mapping-->
    <dependency>
      <artifactId>carml-engine</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-commons</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-model</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-rdf-mapper</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
      <artifactId>carml-logical-source-resolver-jsonpath</artifactId>
      <groupId>com.taxonic.carml</groupId>
      <version>${carml.version}</version>
    </dependency>
    <dependency>
