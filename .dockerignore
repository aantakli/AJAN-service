# VCS / IDE
.git
.github
.idea
.vscode
**/*.iml

# Maven build outputs - Docker uses prebuilt JARs from the dist artifact (overlaid
# at context root and inside pluginsystem/plugins/), never the local target/ dirs.
**/target

# Python caches and pre-built venvs; PythonPlugin unpacks its own embedded venv
# from JAR resources at runtime.
**/__pycache__
**/*.pyc
**/nix_venv

# Source code is not needed by the runtime image.
**/src
**/build-configuration

# Module manifests / module-level POMs
**/pom.xml


# Docs / licenses
*.md
LICENSE*
THIRDPARTY*
AUTHORS.txt
licenseheader*.txt

# Local helper scripts - the CI dist already contains its own start scripts and
# the image runs supervisord directly anyway.
/*.sh
/*.bat
.gitignore
.gitmodules

# Docker meta
.dockerignore
